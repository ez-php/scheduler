{
    "name": "ez-php/scheduler",
    "version": "1.2.0",
    "description": "Cron-based job scheduler with mutex-backed overlap prevention for ez-php applications",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Andreas Uretschnig",
            "email": "andreas.uretschnig@gmail.com"
        }
    ],
    "keywords": [
        "scheduler",
        "php",
        "framework",
        "ez-php"
    ],
    "homepage": "https://github.com/ez-php/scheduler",
    "support": {
        "issues": "https://github.com/ez-php/scheduler/issues",
        "source": "https://github.com/ez-php/scheduler"
    },
    "require": {
        "php": "^8.5"
    },
    "require-dev": {
        "ez-php/docker": "^1.0",
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "ez-php/testing-application": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "EzPhp\\Scheduler\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "cs": "php-cs-fixer fix",
        "analyse": "phpstan analyse",
        "test": "phpunit",
        "full": "composer analyse && composer cs && composer test"
    }
}
